# Ghostty config

# Option+Delete (backward word delete) -> send ESC DEL so Neovim reads <M-BS>
keybind = option+backspace=text:\x1b\x7f

# Option+Fn+Delete (forward word delete) -> send ESC d so Neovim reads <M-d>
keybind = option+delete=esc:d

# Cmd+Left/Right -> send xterm-style Home/End sequences
# (recognised natively by Neovim's terminfo)
keybind = command+left=text:\x1bOH
keybind = command+right=text:\x1bOF

# Cmd+Up/Down -> arrow keys with super modifier (mod 9 = 1+8)
# Neovim reads them as <D-Up> / <D-Down>
keybind = command+up=text:\x1b[1;9A
keybind = command+down=text:\x1b[1;9B

# Cmd+C -> copy terminal selection if there is one,
# otherwise fall through to the running program (Neovim picks it up
# via the kitty keyboard protocol as <D-c>).
keybind = performable:command+c=copy_to_clipboard
